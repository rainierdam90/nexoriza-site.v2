# ─────────────────────────────────────────────────────────────────
# Next Horizons — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────

# Email address that receives contact form submissions
CONTACT_EMAIL=contact@nexthorizons.ae

# "From" address shown in your inbox (must be a verified Resend domain)
CONTACT_FROM=contact@nexthorizons.ae

# Resend API key — get yours free at https://resend.com
# Free tier: 100 emails/day, 3,000/month — more than enough to start
# 1. Sign up at resend.com
# 2. Add & verify your domain (nexthorizons.ae)
# 3. Create an API key and paste it below
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────
# Crisp Live Chat — visitor chat & AI bot   (OPTIONAL)
# ─────────────────────────────────────────────────────────────────
# The Crisp Website ID is hardcoded in components/crisp-chat.tsx,
# so the chat widget works out of the box — you don't need to set
# anything here.
#
# Use this variable only if you want to override the default per
# environment, for example:
#   - Set to your staging Crisp workspace ID on the staging deploy
#   - Set to an empty string ("") to disable the widget on a
#     specific environment (e.g. preview deploys)
#
# Note: must be prefixed with NEXT_PUBLIC_ — Next.js only exposes
# vars with that prefix to the browser, and Crisp needs to read it
# client-side.
# NEXT_PUBLIC_CRISP_WEBSITE_ID=

# ─────────────────────────────────────────────────────────────────
# Stripe — Mockup checkout payments
# ─────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
#
# Use TEST keys (sk_test_..., pk_test_...) while developing.
# Switch to LIVE keys (sk_live_..., pk_live_...) before going live.
#
# If left blank, the unlock button will show a helpful "payment not
# configured" message instead of crashing — so the rest of the site
# keeps working.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret. Get this when you register your
# webhook endpoint in Stripe Dashboard → Developers → Webhooks.
# The endpoint URL is: https://your-domain.com/api/webhooks/stripe
# (For local dev: use the Stripe CLI — see CHECKOUT_SETUP.md)
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────
# Admin Panel — /admin
# ─────────────────────────────────────────────────────────────────
# Password for the admin panel. Pick something long and random.
# Recommended: a passphrase-style password (4+ random words) or
# a 24+ character random string.
ADMIN_PASSWORD=

# Secret used to sign the admin session cookie. MUST be at least
# 32 random characters. Generate one with:
#     openssl rand -base64 48
# (Or paste in any sufficiently long random string.)
# If you change this value, all current admin sessions invalidate.
ADMIN_SESSION_SECRET=

# ─────────────────────────────────────────────────────────────────
# Vercel Blob — Mockup data + screenshot storage
# ─────────────────────────────────────────────────────────────────
# Required for production. Without it, the admin panel can still
# create/edit mockups locally (writing to data/mockups.json and
# public/mockups/) but those changes won't persist on Vercel.
#
# To get a token:
#   1. Vercel Dashboard → your project → Storage tab
#   2. Click "Create Database" → choose "Blob"
#   3. Connect it to your project — Vercel auto-injects the token
#      as BLOB_READ_WRITE_TOKEN in production
#
# For local dev with Blob (optional): copy the token from the
# Vercel dashboard and paste it here. Otherwise leave blank and
# admin uploads will write to /public/mockups/ locally.
BLOB_READ_WRITE_TOKEN=

